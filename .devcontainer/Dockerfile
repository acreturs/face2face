# =============================================================================
# Generated by Claude (Anthropic Claude Code) on 2026-06-12.
# FaceRecon dev environment for the 3DSMC face-reconstruction project.
# All C++ libraries live in this image so every teammate has IDENTICAL versions.
# =============================================================================
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# ---- C++ toolchain + libraries (all from apt -> identical for everyone) ------
# Eigen, OpenCV, HDF5 (used now) + Ceres, dlib, yaml-cpp (used soon: the
# optimizer/fit, facial landmarks, and C++ config parsing).
# NOT HighFive: the Makefile clones it at a pinned version into third_party/,
# because apt's HighFive package is unreliable across Ubuntu versions.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        ca-certificates \
        pkg-config \
        libeigen3-dev \
        libopencv-dev \
        libhdf5-dev \
        libceres-dev \
        libdlib-dev \
        libyaml-cpp-dev \
        # Python only for the proof-of-concept prototype in python/
        python3 \
        python3-pip \
        python3-numpy \
        python3-scipy \
        python3-h5py \
        python3-opencv \
        python3-matplotlib \
        python3-yaml \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
